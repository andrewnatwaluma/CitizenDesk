from django import forms
from .models import Report, Photo

class ReportForm(forms.ModelForm):
    """Form for citizens to submit reports/requests"""
    
    # Extra photo fields (up to 3)
    photo1 = forms.ImageField(required=False, label='Photo 1')
    photo2 = forms.ImageField(required=False, label='Photo 2')
    photo3 = forms.ImageField(required=False, label='Photo 3')
    
    class Meta:
        model = Report
        fields = ['title', 'report_type', 'description', 'location', 'ministry', 'is_security_related']
        widgets = {
            'title': forms.TextInput(attrs={
                'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg',
                'placeholder': 'Brief title of your report/request'
            }),
            'description': forms.Textarea(attrs={
                'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg',
                'rows': 4,
                'placeholder': 'Describe the issue or request in detail...'
            }),
            'location': forms.TextInput(attrs={
                'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg',
                'placeholder': 'e.g., Kampala, Namuwongo near the mosque'
            }),
            'ministry': forms.Select(attrs={
                'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg'
            }),
            'report_type': forms.Select(attrs={
                'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg'
            }),
            'is_security_related': forms.CheckboxInput(attrs={
                'class': 'mr-2'
            }),
        }
        labels = {
            'title': 'Title',
            'report_type': 'Report Type',
            'description': 'Description',
            'location': 'Location',
            'ministry': 'Select Ministry',
            'is_security_related': 'This is a security-related report (handled discreetly)',
        }0

